{
  "manifest_version": 3,
  "name": "로젠 토큰 릴레이 (kuaai)",
  "version": "1.2",
  "description": "logis.ilogen.com JWT를 logen-cafe24 서버에 자동 저장",
  "content_scripts": [
    {
      "matches": ["https://logis.ilogen.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "http://localhost:8080/*"
  ]
}
